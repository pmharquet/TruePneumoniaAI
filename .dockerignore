# Keep the build context small — datasets, artifacts and caches come in as
# bind-mounted volumes at runtime, not baked into the image.
.venv/
.git/
__pycache__/
**/__pycache__/
*.pyc

# Datasets (mounted as volumes)
dataset/
chest_Xray*/

# Runtime artifacts (mounted as volumes)
outputs/
mlruns/
checkpoints/
exports/

# Misc
.idea/
.vscode/
*.log
node_modules/
site/
